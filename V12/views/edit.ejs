<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Document</title>
        <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.tailwindcss.com"></script>
        </head>
        <body>
            
            <div class="w-full h-full bg-zinc-900 p-10 text-white">
                <div class="nav mb-10">
                    <a class="text-blue-500" href="/read">Update User</a>
                    
                </div>
                <form action="/update/<%= user._id %>" method="post">
                    <input type="text" class="px-5 py-3 bg-transparent" name="name" placeholder="name" value="<%= user.name %>">
                     <input type="text" class="px-5 py-3 bg-transparent" name="email" placeholder="email" value="<%= user.email %>">
                      <input type="text" class="px-5 py-3 bg-transparent" name="image" placeholder="image url" value="<%= user.image %>">
                      <input class="px-5 py-2 bg-yellow-500 rounded-lg" type="submit" value="Update User">

                </form>
            </div>
            
            <script src="/javascripts/script.js"></script>
        </body>
        </html>
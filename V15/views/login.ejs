<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Document</title>
        <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.tailwindcss.com"></script>
        </head>
        <body>
            
            <div class="w-full h-full bg-zinc-900 p-10 text-white">
                <h3 class="text-3xl mb-3">Login</h3>
              <form method="post" action="/login">

                <input type="email" class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800" placeholder="email" name="email">
                <input type="password" class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800" placeholder="password" name="password">
                 <input class="px-5 py-2 bg-blue-500 rounded-lg" type="submit" value="Login">
              </form>
            </div>
            
            <script src="/javascripts/script.js"></script>
        </body>
        </html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form px-10 py-10 text-white">
            <form action="/create" method="post">
                <input class="block w-full rounded-lg px-5 py-3 bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" placeholder="Title goes here" name="title">
                <textarea class="block w-full mt-2 px-5 py-3  resize-none bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Write your task details here" name="details"></textarea>
                <input class="block mt-2 px-5 py-3 bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" type="submit" value="create task">
            </form>
        </div>
        <div class="tasks flex gap-4 flex-wrap p-10">
            <% if(files.length > 0){ %>
            <% files.forEach(function(val){%>
                  <div class="task mb-4 p-3 bg-zinc-700 rounded-lg">
                <h1 class="text-2xl font-bold mb-4 tracking-wide"><%= val %></h1>
                <div class="flex bg-zinc-900 w-full justify-between">

                    <a  class="text-blue-500 hover:text-blue-700" href="/file/<%= val %>">View All Tasks</a>
                    <a href="/edit/<%= val %>" class="text-zinc-500 hover:text-zinc-300 ml-4">Edit</a> 
                </div>
            </div>
                <% }) %>
                <% } else { %>
                    <h3 class="text-xl text-zinc-500"> no tasks available </h3>
                    <% } %>

                <h1 class="text-2xl font-bold mb-4 tracking-wide">Tasks</h1>
                <a href="" class="text-blue-500 hover:text-blue-700">View All Tasks</a>
            </div>
             <div class="task hidden mb-4 p-3 bg-zinc-700 rounded-lg">
                <h1 class="text-2xl font-bold mb-4 tracking-wide">Tasks</h1>
                <a href="" class="text-blue-500 hover:text-blue-700">View All Tasks</a>
            </div>
             <div class="task hidden mb-4 p-3 bg-zinc-700 rounded-lg">
                <h1 class="text-2xl font-bold mb-4 tracking-wide">Tasks</h1>
                <a href="" class="text-blue-500 hover:text-blue-700">View All Tasks</a>
            </div> -->
            <!--  <h3 class="text-xl text-zinc-500"> no tasks available </h3> -->
        </div> 

    </div>
</body>
</html>
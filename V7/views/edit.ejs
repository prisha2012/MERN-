<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Edit Task</title>
        <script src="https://cdn.tailwindcss.com"></script>
        </head>
    <body>
        <div class="main w-full min-h-screen bg-zinc-900">
        <a class="text-blue-500 hover:text-blue-700" href="/"> go back to home</a>
       
          <form action="/edit" method="post">
                <input class="block w-full rounded-lg px-5 py-3 bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" placeholder="Previous Title" name="previousTitle" value="<%= filename%>" disabled="true">
                <input class="block w-full rounded-lg px-5 py-3 bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" placeholder="New Title" name="title">
              
                <input class="block mt-2 px-5 py-3 bg-white text-black hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" type="submit" value="Update Task">
            </form>
        </div>
        </body>
</html>